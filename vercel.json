{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/how-it-works",
      "destination": "/how-it-works.html"
    },
    {
      "source": "/terms-privacy",
      "destination": "/terms-privacy.html"
    },
    {
      "source": "/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/screen",
      "destination": "/screen.html"
    },
    {
      "source": "/notepad",
      "destination": "/notepad.html"
    },
    {
      "source": "/json-formatter",
      "destination": "/json-formatter.html"
    },
    {
      "source": "/Diff",
      "destination": "/Diff.html"
    }
  ]
}